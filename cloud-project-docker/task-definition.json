{
  "family": "cloud-project-task",
  "executionRoleArn": "arn:aws:iam::149536456043:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "cloud-project-container",
      "image": "149536456043.dkr.ecr.us-east-1.amazonaws.com/cloud-project:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "protocol": "tcp"
        }
      ]
    }
  ]
}